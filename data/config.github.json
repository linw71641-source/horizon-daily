{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-chat",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 0,
    "analysis_concurrency": 2,
    "enrichment_concurrency": 1
  },
  "languages": ["zh", "en"],
  "email": {
    "enabled": false
  },
  "sources": {
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 100
    },
    "github": [
      {
        "type": "user_events",
        "username": "torvalds",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "astral-sh",
        "repo": "uv",
        "enabled": true
      },
      {
        "type": "user_events",
        "username": "karpathy",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "vllm-project",
        "repo": "vllm",
        "enabled": true
      }
    ],
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "量子位",
        "url": "https://wechat2rss.xlab.app/feed/7131b577c61365cb47e81000738c10d872685908.xml",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "新智元",
        "url": "https://wechat2rss.xlab.app/feed/ede30346413ea70dbef5d485ea5cbb95cca446e7.xml",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "Krebs on Security",
        "url": "https://krebsonsecurity.com/feed/",
        "enabled": true,
        "category": "security"
      },
      {
        "name": "Schneier on Security",
        "url": "https://www.schneier.com/feed/atom/",
        "enabled": true,
        "category": "security"
      },
      {
        "name": "BBC World News",
        "url": "https://feeds.bbci.co.uk/news/world/rss.xml",
        "enabled": true,
        "category": "politics"
      },
      {
        "name": "The Guardian World",
        "url": "https://www.theguardian.com/world/rss",
        "enabled": true,
        "category": "politics"
      },
      {
        "name": "BBC Sport Football",
        "url": "https://feeds.bbci.co.uk/sport/football/rss.xml",
        "enabled": true,
        "category": "football"
      },
      {
        "name": "The Guardian Football",
        "url": "https://www.theguardian.com/football/rss",
        "enabled": true,
        "category": "football"
      },
      {
        "name": "ESPN NBA",
        "url": "https://www.espn.com/espn/rss/nba/news",
        "enabled": true,
        "category": "basketball"
      }
    ],
    "reddit": {
      "enabled": true,
      "fetch_comments": 5,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 50
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "fetch_limit": 15,
          "min_score": 60
        },
        {
          "subreddit": "netsec",
          "enabled": true,
          "sort": "hot",
          "fetch_limit": 15,
          "min_score": 50
        }
      ],
      "users": []
    },
    "twitter": {
      "enabled": false
    },
    "openbb": {
      "enabled": false
    },
    "ossinsight": {
      "enabled": false,
      "period": "past_24_hours",
      "languages": ["All", "Python", "TypeScript"],
      "keywords": [],
      "min_stars": 10,
      "max_items": 30
    },
    "telegram": {
      "enabled": false
    }
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 48
  },
  "webhook": {
    "enabled": false
  }
}
